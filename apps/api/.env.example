# Copy thành .env và điền giá trị thật. KHÔNG commit .env.
NODE_ENV=development
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://vpb:vpb_local_dev@localhost:5432/vpb?schema=public

# openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth (Phase 0.5 — để trống được cho tới khi bật tính năng)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Cloudflare R2 (S3-compatible) — storage cho Asset
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_S3_URL=
CLOUDFLARE_R2_PUBLIC_URL=
